{
  "name": "byreal-cli",
  "version": "0.1.0",
  "description": "AI-friendly CLI for Byreal CLMM DEX on Solana",
  "type": "module",
  "main": "dist/index.cjs",
  "bin": {
    "byreal-cli": "dist/index.cjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/byreal-git/byreal-cli.git"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --outfile=dist/index.cjs --format=cjs --platform=node --target=node18 --banner:js=\"#!/usr/bin/env node\nvar _cw=console.warn;console.warn=function(){var s=arguments[0];if(typeof s==='string'&&s.includes('Failed to load bindings'))return;_cw.apply(console,arguments)};var _pe=process.emit;process.emit=function(e,a){if(e==='warning'&&a&&a.name==='DeprecationWarning')return false;return _pe.apply(this,arguments)};\"",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "clean": "rm -rf dist",
    "prepare": "test -f dist/index.cjs || npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "byreal",
    "solana",
    "clmm",
    "dex",
    "cli",
    "defi",
    "liquidity"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/index.cjs",
    "skills/"
  ],
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/buffer-layout": "^4.0.1",
    "@solana/spl-memo": "^0.2.5",
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.98.2",
    "bn.js": "^5.2.1",
    "bs58": "^6.0.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "decimal.js": "^10.5.0",
    "dotenv": "^16.4.5",
    "ky": "^1.7.2",
    "lodash-es": "^4.17.21"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.5",
    "@types/node": "^20.17.6",
    "esbuild": "^0.24.0",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
